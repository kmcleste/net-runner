FROM python:3.11-slim

WORKDIR /app
COPY pyproject.toml .
COPY net_runner/ ./net_runner/
COPY remediation/ ./remediation/

RUN pip install --no-cache-dir -e .

EXPOSE 9000

# PORT is injected by Railway at runtime; fall back to 9000 locally.
CMD ["sh", "-c", "uvicorn remediation.main:app --host 0.0.0.0 --port ${PORT:-9000}"]
